# Local development environment variables for Cloudflare Workers (via Wrangler)
# Copy this file to .dev.vars and fill in the real values.
# Never commit .dev.vars — it is listed in .gitignore.

# Resend API key — required for contact form and estimate email features
# Obtain from https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_KEY_HERE
